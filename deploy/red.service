[Unit]
Description=Red Dragonfly Chatroom
After=network.target

[Service]
Type=simple
User=www
Group=www
WorkingDirectory=/opt/red/current
EnvironmentFile=/opt/red/current/.env
ExecStart=/opt/red/current/.venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --proxy-headers
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
